# ─── Terraform ────────────────────────────────────────────────
# Plugin cache and downloaded providers — regenerated by terraform init
.terraform/
# Local state files — this project uses S3 remote state
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
crash.log
crash.*.log
# Override files are local experiments, never shared
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Root-level terraform.tfvars could accidentally hold secrets;
# shared config lives in environments/*.tfvars which IS committed
terraform.tfvars
terraform.tfvars.json
